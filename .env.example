# Database — local Docker Postgres for development (run `pnpm db:start`)
# In production, Vercel auto-injects this via the Neon Marketplace integration
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/bakery-test

# Payload CMS
PAYLOAD_SECRET=your-secret-here-min-32-chars

# Vercel Blob Storage (for media uploads)
# Leave empty for local dev — media uploads save to disk. Set in production via Vercel.
BLOB_READ_WRITE_TOKEN=

# Site URL (used for SEO, OG images, preview links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
